---
const channels = [
  { name: 'WhatsApp', color: '#25D366', icon: 'W' },
  { name: 'Telegram', color: '#0088CC', icon: 'T' },
  { name: 'Instagram', color: '#E4405F', icon: 'I' },
  { name: 'SMS', color: '#FFD700', icon: 'S' },
  { name: 'Discord', color: '#5865F2', icon: 'D' },
  { name: 'Slack', color: '#4A154B', icon: 'Sl' },
  { name: 'Email', color: '#6C5CE7', icon: 'E' },
];
---

<section id="channels" class="relative py-28 sm:py-36 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-midnight"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/10 to-transparent"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-violet/[0.02] rounded-full blur-[120px]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Two-column layout -->
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <!-- Left: Content -->
      <div class="reveal-left">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-gold"></div>
          <span class="font-body text-xs font-semibold text-gold uppercase tracking-[0.2em]">7 Channels</span>
        </div>

        <h2 class="font-heading font-bold text-4xl sm:text-5xl md:text-[3.5rem] text-purple-mist leading-[1.1] mb-6">
          Your reminders.<br />
          Your channels.<br />
          <span class="text-gold">Your way.</span>
        </h2>

        <p class="font-body text-lg text-purple-mist/60 leading-relaxed mb-10 max-w-lg">
          Set up escalation chains so you never miss what matters. First a push, then WhatsApp, then SMS. You decide the sequence.
        </p>

        <!-- Escalation chain demo -->
        <div class="flex items-center gap-3 mb-12">
          <div class="flex items-center">
            <div class="w-9 h-9 rounded-lg bg-violet/15 flex items-center justify-center">
              <svg class="w-4 h-4 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </div>
            <div class="w-8 h-px bg-gradient-to-r from-violet/30 to-green-500/30"></div>
          </div>
          <div class="flex items-center">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: rgba(37, 211, 102, 0.15);">
              <span class="text-[#25D366] font-bold text-xs">W</span>
            </div>
            <div class="w-8 h-px bg-gradient-to-r from-green-500/30 to-gold/30"></div>
          </div>
          <div class="flex items-center">
            <div class="w-9 h-9 rounded-lg bg-gold/10 flex items-center justify-center">
              <span class="text-gold font-bold text-xs">S</span>
            </div>
          </div>
          <span class="font-body text-[11px] text-purple-mist/50 ml-2">Push → WhatsApp → SMS</span>
        </div>

        <!-- Channel grid -->
        <div class="grid grid-cols-4 sm:grid-cols-7 gap-3">
          {channels.map((channel, i) => (
            <div class="group flex flex-col items-center gap-2 cursor-pointer">
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center font-heading font-bold text-sm text-white transition-all duration-500 group-hover:scale-110 group-hover:shadow-lg channel-icon"
                style={`background: ${channel.color}; --glow: ${channel.color}40;`}
              >
                {channel.icon}
              </div>
              <span class="font-body text-[10px] text-purple-mist/50 group-hover:text-purple-mist/70 transition-colors duration-300">
                {channel.name}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="flex justify-center reveal-right">
        <div class="relative">
          <!-- Orbital rings -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-[280px] h-[280px] sm:w-[340px] sm:h-[340px] rounded-full border border-violet/[0.06]"></div>
            <div class="absolute w-[380px] h-[380px] sm:w-[440px] sm:h-[440px] rounded-full border border-violet/[0.04] border-dashed"></div>
          </div>

          <!-- Orbiting channel icons -->
          <div class="absolute inset-0 flex items-center justify-center">
            {channels.map((channel, i) => (
              <div
                class="absolute w-10 h-10 rounded-xl flex items-center justify-center font-heading font-bold text-xs text-white shadow-lg orbit-item"
                style={`
                  background: ${channel.color};
                  box-shadow: 0 0 20px ${channel.color}30;
                  --orbit-radius: ${i < 4 ? '140px' : '190px'};
                  --orbit-start: ${i * (360 / channels.length)}deg;
                  --orbit-duration: ${i < 4 ? '30' : '40'}s;
                  --orbit-direction: ${i < 4 ? 'normal' : 'reverse'};
                `}
              >
                {channel.icon}
              </div>
            ))}
          </div>

          <!-- Center phone -->
          <div class="relative w-[200px] h-[360px] sm:w-[220px] sm:h-[400px] mx-auto">
            <!-- Glow -->
            <div class="absolute -inset-6 bg-gradient-to-b from-violet/10 to-gold/5 rounded-[2.5rem] blur-xl"></div>

            <!-- Phone body -->
            <div class="relative w-full h-full rounded-[2rem] border border-violet/20 bg-midnight-light/90 backdrop-blur-xl overflow-hidden shadow-2xl">
              <!-- Notch -->
              <div class="absolute top-2 left-1/2 -translate-x-1/2 w-16 h-5 bg-black rounded-full z-10"></div>

              <!-- Screen -->
              <div class="absolute inset-[2px] rounded-[1.9rem] bg-gradient-to-b from-midnight-lighter to-midnight overflow-hidden">
                <!-- Status bar -->
                <div class="px-6 pt-3.5 flex items-center justify-between">
                  <span class="text-[9px] text-purple-mist/30 font-medium">9:41</span>
                  <div class="flex items-center gap-1">
                    <div class="w-5 h-2.5 rounded-sm border border-purple-mist/20 flex items-center justify-end pr-[1px]">
                      <div class="w-3 h-[5px] rounded-[1px] bg-gold/60"></div>
                    </div>
                  </div>
                </div>

                <!-- Notification stack -->
                <div class="px-3 pt-8 space-y-2">
                  <div class="notification-card p-2.5 rounded-xl bg-white/[0.03] border border-white/[0.04]" style="animation-delay: 0s;">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-md bg-[#25D366] flex items-center justify-center flex-shrink-0">
                        <span class="text-white text-[8px] font-bold">W</span>
                      </div>
                      <div>
                        <p class="text-[9px] font-semibold text-purple-mist/80">WhatsApp</p>
                        <p class="text-[8px] text-purple-mist/30">Meeting in 15 min</p>
                      </div>
                      <span class="text-[7px] text-purple-mist/20 ml-auto">now</span>
                    </div>
                  </div>

                  <div class="notification-card p-2.5 rounded-xl bg-white/[0.03] border border-white/[0.04]" style="animation-delay: 1s;">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-md bg-[#0088CC] flex items-center justify-center flex-shrink-0">
                        <span class="text-white text-[8px] font-bold">T</span>
                      </div>
                      <div>
                        <p class="text-[9px] font-semibold text-purple-mist/80">Telegram</p>
                        <p class="text-[8px] text-purple-mist/30">Ship v2.1 by EOD</p>
                      </div>
                      <span class="text-[7px] text-purple-mist/20 ml-auto">2m</span>
                    </div>
                  </div>

                  <div class="notification-card p-2.5 rounded-xl bg-white/[0.03] border border-white/[0.04]" style="animation-delay: 2s;">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-md bg-[#E4405F] flex items-center justify-center flex-shrink-0">
                        <span class="text-white text-[8px] font-bold">I</span>
                      </div>
                      <div>
                        <p class="text-[9px] font-semibold text-purple-mist/80">Instagram</p>
                        <p class="text-[8px] text-purple-mist/30">Review design files</p>
                      </div>
                      <span class="text-[7px] text-purple-mist/20 ml-auto">5m</span>
                    </div>
                  </div>

                  <div class="notification-card p-2.5 rounded-xl bg-white/[0.03] border border-white/[0.04]" style="animation-delay: 3s;">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-md bg-[#5865F2] flex items-center justify-center flex-shrink-0">
                        <span class="text-white text-[8px] font-bold">D</span>
                      </div>
                      <div>
                        <p class="text-[9px] font-semibold text-purple-mist/80">Discord</p>
                        <p class="text-[8px] text-purple-mist/30">Team standup at 3 PM</p>
                      </div>
                      <span class="text-[7px] text-purple-mist/20 ml-auto">8m</span>
                    </div>
                  </div>

                  <div class="notification-card p-2.5 rounded-xl bg-white/[0.03] border border-white/[0.04]" style="animation-delay: 4s;">
                    <div class="flex items-center gap-2">
                      <div class="w-6 h-6 rounded-md bg-[#FFD700] flex items-center justify-center flex-shrink-0">
                        <span class="text-midnight text-[8px] font-bold">S</span>
                      </div>
                      <div>
                        <p class="text-[9px] font-semibold text-purple-mist/80">SMS</p>
                        <p class="text-[8px] text-purple-mist/30">Urgent: Client call</p>
                      </div>
                      <span class="text-[7px] text-purple-mist/20 ml-auto">12m</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Home indicator -->
              <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 w-24 h-1 rounded-full bg-purple-mist/10"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .channel-icon:hover {
    box-shadow: 0 0 24px var(--glow);
  }

  .orbit-item {
    animation: orbitChannel var(--orbit-duration) linear infinite var(--orbit-direction);
  }

  @keyframes orbitChannel {
    0% {
      transform: rotate(var(--orbit-start)) translateX(var(--orbit-radius)) rotate(calc(-1 * var(--orbit-start)));
    }
    100% {
      transform: rotate(calc(var(--orbit-start) + 360deg)) translateX(var(--orbit-radius)) rotate(calc(-1 * (var(--orbit-start) + 360deg)));
    }
  }

  /* Hide orbiting icons on mobile */
  @media (max-width: 640px) {
    .orbit-item {
      display: none;
    }
  }

  .notification-card {
    animation: notifSlide 6s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  @keyframes notifSlide {
    0% { opacity: 0; transform: translateY(8px); }
    10%, 90% { opacity: 1; transform: translateY(0); }
    100% { opacity: 1; transform: translateY(0); }
  }
</style>
