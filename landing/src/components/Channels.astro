---
const channels = [
  { name: 'WhatsApp', color: '#25D366', icon: 'W' },
  { name: 'Telegram', color: '#0088CC', icon: 'T' },
  { name: 'Instagram', color: '#E4405F', icon: 'I' },
  { name: 'SMS', color: '#FFD700', icon: 'S' },
  { name: 'Discord', color: '#5865F2', icon: 'D' },
  { name: 'Slack', color: '#4A154B', icon: 'Sl' },
  { name: 'Email', color: '#6C5CE7', icon: 'E' },
];
---

<section id="channels" class="relative py-28 sm:py-36 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-midnight via-midnight-light/30 to-midnight"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/15 to-transparent"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-violet/[0.05] rounded-full blur-[120px]"></div>
  <div class="absolute bottom-1/3 left-1/4 w-[400px] h-[400px] bg-gold/[0.03] rounded-full blur-[100px]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <!-- Left -->
      <div class="reveal-left">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-gold"></div>
          <span class="font-body text-xs font-semibold text-gold uppercase tracking-[0.2em]">7 Channels</span>
        </div>

        <h2 class="font-heading font-bold text-4xl sm:text-5xl md:text-[3.5rem] text-purple-mist leading-[1.1] mb-6">
          Your reminders.<br />
          Your channels.<br />
          <span class="text-gold">Your way.</span>
        </h2>

        <p class="font-body text-lg text-purple-mist/55 leading-relaxed mb-10 max-w-lg">
          Set up escalation chains so you never miss what matters. First a push, then WhatsApp, then SMS. You decide the sequence.
        </p>

        <!-- Escalation chain with gradient connecting lines -->
        <div class="relative flex items-center gap-3 mb-12">
          <div class="flex items-center">
            <div class="w-10 h-10 rounded-xl glass-medium flex items-center justify-center">
              <svg class="w-4 h-4 text-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </div>
            <div class="escalation-line w-8 h-[2px]"></div>
          </div>
          <div class="flex items-center">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(37, 211, 102, 0.15);">
              <span class="text-[#25D366] font-bold text-xs">W</span>
            </div>
            <div class="escalation-line w-8 h-[2px]"></div>
          </div>
          <div class="w-10 h-10 rounded-xl bg-gold/10 flex items-center justify-center">
            <span class="text-gold font-bold text-xs">S</span>
          </div>
          <span class="font-body text-[11px] text-purple-mist/40 ml-2">Push &rarr; WhatsApp &rarr; SMS</span>
        </div>

        <!-- Channel grid -->
        <div class="grid grid-cols-4 sm:grid-cols-7 gap-3">
          {channels.map((channel) => (
            <div class="group flex flex-col items-center gap-2 cursor-pointer">
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center font-heading font-bold text-sm text-white transition-all duration-500 group-hover:scale-110 group-hover:shadow-lg"
                style={`background: ${channel.color}; box-shadow: 0 0 0 rgba(0,0,0,0);`}
              >
                {channel.icon}
              </div>
              <span class="font-body text-[10px] text-purple-mist/40 group-hover:text-purple-mist/60 transition-colors duration-300">
                {channel.name}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Orbital visualization -->
      <div class="flex justify-center reveal-right">
        <div class="relative">
          <!-- Orbital rings with parallax -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div
              class="w-[280px] h-[280px] sm:w-[340px] sm:h-[340px] rounded-full border border-violet/[0.06]"
              data-parallax
              data-parallax-speed="0.015"
            ></div>
            <div
              class="absolute w-[380px] h-[380px] sm:w-[440px] sm:h-[440px] rounded-full border border-violet/[0.04] border-dashed"
              data-parallax
              data-parallax-speed="0.025"
            ></div>
          </div>

          <!-- Orbiting icons with parallax -->
          <div class="absolute inset-0 flex items-center justify-center">
            {channels.map((channel, i) => (
              <div
                class="absolute w-10 h-10 rounded-xl flex items-center justify-center font-heading font-bold text-xs text-white shadow-lg orbit-item"
                data-parallax
                data-parallax-speed={`${0.01 + i * 0.005}`}
                style={`
                  background: ${channel.color};
                  box-shadow: 0 0 20px ${channel.color}30;
                  --orbit-radius: ${i < 4 ? '140px' : '190px'};
                  --orbit-start: ${i * (360 / channels.length)}deg;
                  --orbit-duration: ${i < 4 ? '30' : '40'}s;
                  --orbit-direction: ${i < 4 ? 'normal' : 'reverse'};
                `}
              >
                {channel.icon}
              </div>
            ))}
          </div>

          <!-- Glowing pulse behind center phone -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[180px] h-[320px] sm:w-[200px] sm:h-[360px] pointer-events-none" aria-hidden="true">
            <div class="phone-pulse-glow absolute inset-0 rounded-[2.5rem] bg-violet/[0.12] blur-[40px]"></div>
          </div>

          <!-- Center phone as tilt-card -->
          <div class="tilt-card relative w-[200px] h-[360px] sm:w-[220px] sm:h-[400px] mx-auto">
            <div class="absolute -inset-6 bg-gradient-to-b from-violet/10 to-gold/5 rounded-[2.5rem] blur-xl"></div>
            <div class="relative w-full h-full rounded-[2rem] glass-heavy overflow-hidden shadow-2xl">
              <div class="absolute top-2 left-1/2 -translate-x-1/2 w-16 h-5 bg-black rounded-full z-10"></div>
              <div class="absolute inset-[2px] rounded-[1.9rem] bg-gradient-to-b from-midnight-lighter to-midnight overflow-hidden">
                <div class="px-6 pt-3.5 flex items-center justify-between">
                  <span class="text-[9px] text-purple-mist/30 font-medium">9:41</span>
                  <div class="w-5 h-2.5 rounded-sm border border-purple-mist/20 flex items-center justify-end pr-[1px]">
                    <div class="w-3 h-[5px] rounded-[1px] bg-gold/60"></div>
                  </div>
                </div>

                <div class="px-3 pt-8 space-y-2">
                  {channels.slice(0, 5).map((ch, i) => (
                    <div
                      class="notif-stagger p-2.5 rounded-xl glass-light"
                      style={`--notif-delay: ${i * 0.15}s;`}
                    >
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0" style={`background: ${ch.color};`}>
                          <span class={`text-[8px] font-bold ${ch.name === 'SMS' ? 'text-midnight' : 'text-white'}`}>{ch.icon}</span>
                        </div>
                        <div>
                          <p class="text-[9px] font-semibold text-purple-mist/80">{ch.name}</p>
                          <p class="text-[8px] text-purple-mist/30">Reminder notification</p>
                        </div>
                        <span class="text-[7px] text-purple-mist/20 ml-auto">{['now', '2m', '5m', '8m', '12m'][i]}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              <div class="absolute bottom-1.5 left-1/2 -translate-x-1/2 w-24 h-1 rounded-full bg-purple-mist/10"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Escalation connecting lines */
  .escalation-line {
    background: linear-gradient(90deg, rgba(108, 92, 231, 0.3), rgba(255, 215, 0, 0.3));
    position: relative;
  }
  .escalation-line::after {
    content: '';
    position: absolute;
    top: 50%;
    right: -2px;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 215, 0, 0.4);
  }

  /* Orbit animation */
  .orbit-item {
    animation: orbitChannel var(--orbit-duration) linear infinite var(--orbit-direction);
  }

  @keyframes orbitChannel {
    0% { transform: rotate(var(--orbit-start)) translateX(var(--orbit-radius)) rotate(calc(-1 * var(--orbit-start))); }
    100% { transform: rotate(calc(var(--orbit-start) + 360deg)) translateX(var(--orbit-radius)) rotate(calc(-1 * (var(--orbit-start) + 360deg))); }
  }

  @media (max-width: 640px) {
    .orbit-item { display: none; }
  }

  /* Phone pulse glow */
  .phone-pulse-glow {
    animation: phonePulse 3s ease-in-out infinite;
  }

  @keyframes phonePulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.08); }
  }

  /* Notification stagger: slide + fade */
  .notif-stagger {
    opacity: 0;
    transform: translateY(12px) translateX(-6px);
    animation: notifStaggerIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--notif-delay, 0s);
  }

  @keyframes notifStaggerIn {
    0% {
      opacity: 0;
      transform: translateY(12px) translateX(-6px);
    }
    100% {
      opacity: 1;
      transform: translateY(0) translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orbit-item,
    .phone-pulse-glow,
    .notif-stagger {
      animation: none;
    }
    .notif-stagger {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Re-trigger notification stagger when visible
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const channelsSection = document.getElementById('channels');
    if (channelsSection) {
      const notifObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const notifs = channelsSection.querySelectorAll('.notif-stagger');
              notifs.forEach((n) => {
                const el = n as HTMLElement;
                el.style.animation = 'none';
                // Force reflow
                void el.offsetHeight;
                el.style.animation = '';
              });
              notifObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3 }
      );
      notifObserver.observe(channelsSection);
    }
  }
</script>
