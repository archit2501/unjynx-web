---

<!-- CTA Banner -->
<section class="relative py-28 sm:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-midnight"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/10 to-transparent"></div>

  <!-- Background accents -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet/[0.04] rounded-full blur-[120px]"></div>
  <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-gold/[0.02] rounded-full blur-[100px]"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
    <h2 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-purple-mist leading-[1.1] mb-6">
      Ready to unjynx<br />
      <span class="cta-gradient">your productivity?</span>
    </h2>
    <p class="font-body text-lg text-purple-mist/60 max-w-lg mx-auto mb-10">
      Download now. Set up in 2 minutes. Start getting reminders where you'll actually see them.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#"
        class="group relative flex items-center gap-3 px-8 py-4 overflow-hidden rounded-2xl"
      >
        <span class="absolute inset-0 bg-gold rounded-2xl"></span>
        <span class="absolute inset-0 bg-gradient-to-r from-gold via-yellow-300 to-gold opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-2xl"></span>
        <span class="absolute inset-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)] rounded-2xl"></span>
        <svg class="relative w-5 h-5 text-midnight" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <span class="relative font-heading font-bold text-base text-midnight">Download for iOS</span>
      </a>
      <a
        href="#"
        class="group flex items-center gap-3 px-8 py-4 rounded-2xl border border-violet/20 hover:border-violet/40 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-500"
      >
        <svg class="w-5 h-5 text-purple-mist/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.834 1.64a1 1 0 0 1 0 1.74l-2.834 1.64-2.532-2.533 2.532-2.488zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/>
        </svg>
        <span class="font-heading font-bold text-base text-purple-mist group-hover:text-gold transition-colors duration-300">Download for Android</span>
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="relative border-t border-white/[0.03]">
  <div class="absolute inset-0 bg-gradient-to-b from-midnight to-[#080510]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main footer -->
    <div class="py-16 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-10 lg:gap-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-4 lg:col-span-2">
        <a href="/unjynx-web/" class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-violet to-deep-violet flex items-center justify-center">
            <span class="font-heading font-black text-gold text-base leading-none">U</span>
          </div>
          <span class="font-heading font-bold text-xl text-purple-mist tracking-tight">UNJYNX</span>
        </a>
        <p class="font-body text-sm text-purple-mist/50 leading-relaxed mb-6 max-w-xs">
          Break the satisfactory. Unjynx your productivity. The TODO app that reaches you everywhere.
        </p>
        <div class="flex items-center gap-3">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              class="w-9 h-9 rounded-lg border border-white/[0.04] bg-white/[0.02] flex items-center justify-center text-purple-mist/30 hover:text-gold hover:border-gold/20 transition-all duration-300"
              aria-label={social.label}
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="font-heading font-semibold text-xs text-purple-mist/50 uppercase tracking-[0.15em] mb-5">
          Product
        </h4>
        <ul class="space-y-3">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-purple-mist/50 hover:text-gold transition-colors duration-300 inline-block py-1">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-heading font-semibold text-xs text-purple-mist/50 uppercase tracking-[0.15em] mb-5">
          Company
        </h4>
        <ul class="space-y-3">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-purple-mist/50 hover:text-gold transition-colors duration-300 inline-block py-1">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-heading font-semibold text-xs text-purple-mist/50 uppercase tracking-[0.15em] mb-5">
          Legal
        </h4>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-purple-mist/50 hover:text-gold transition-colors duration-300 inline-block py-1">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t border-white/[0.03] flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-body text-[11px] text-purple-mist/20">
        &copy; 2026 UNJYNX. All rights reserved.
      </p>
      <p class="font-body text-[11px] text-purple-mist/15">
        Made with purpose by <span class="text-violet/40 hover:text-violet/60 transition-colors duration-300">METAminds</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .cta-gradient {
    background: linear-gradient(135deg, #FFD700, #6C5CE7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
