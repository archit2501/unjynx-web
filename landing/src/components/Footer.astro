---
const productLinks = [
  { label: 'Features', href: '#features' },
  { label: 'Channels', href: '#channels' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];

const companyLinks = [
  { label: 'Blog', href: '#' },
  { label: 'Support', href: '#' },
  { label: 'Careers', href: '#' },
  { label: 'Contact', href: '#' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/unjynx-web/privacy' },
  { label: 'Terms of Service', href: '/unjynx-web/terms' },
];

const socialLinks = [
  { label: 'Twitter / X', href: '#', icon: `<svg class="w-4 h-4" fill="currentColor" aria-hidden="true" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>` },
  { label: 'Instagram', href: '#', icon: `<svg class="w-4 h-4" fill="currentColor" aria-hidden="true" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>` },
  { label: 'LinkedIn', href: '#', icon: `<svg class="w-4 h-4" fill="currentColor" aria-hidden="true" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>` },
  { label: 'GitHub', href: '#', icon: `<svg class="w-4 h-4" fill="currentColor" aria-hidden="true" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>` },
];
---

<!-- CTA Banner -->
<section class="relative py-16 sm:py-28 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-midnight"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/10 to-transparent"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet/[0.04] rounded-full blur-[120px]"></div>

  <!-- Animated glow orbs behind the CTA text -->
  <div class="absolute top-1/3 left-1/3 w-[250px] h-[250px] rounded-full bg-gold/[0.06] blur-[80px] cta-orb-1 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-1/3 right-1/3 w-[200px] h-[200px] rounded-full bg-violet/[0.08] blur-[70px] cta-orb-2 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full bg-deep-violet/[0.05] blur-[100px] cta-orb-3 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
    <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-purple-mist leading-[1.1] mb-4 sm:mb-6">
      Ready to unjynx<br />
      <span class="cta-gradient">your productivity?</span>
    </h2>
    <p class="font-body text-lg text-purple-mist/50 max-w-lg mx-auto mb-10">
      Download now. Set up in 2 minutes. Start getting reminders where you'll actually see them.
    </p>

    <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-4 w-full sm:w-auto">
      <a href="#" class="group relative flex items-center justify-center gap-3 px-8 py-4 min-h-[48px] overflow-hidden rounded-2xl glass-heavy hover:bg-white/[0.12] transition-all duration-500 border-gold/20">
        <div class="absolute inset-0 bg-gradient-to-r from-gold/10 via-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
        <svg class="relative w-5 h-5 text-gold" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <span class="relative font-heading font-bold text-base text-purple-mist">Download for iOS</span>
      </a>
      <a href="#" class="group flex items-center justify-center gap-3 px-8 py-4 min-h-[48px] rounded-2xl glass-light hover:bg-white/[0.06] transition-all duration-500">
        <svg class="w-5 h-5 text-purple-mist/70" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.834 1.64a1 1 0 0 1 0 1.74l-2.834 1.64-2.532-2.533 2.532-2.488zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/>
        </svg>
        <span class="font-heading font-bold text-base text-purple-mist group-hover:text-gold transition-colors duration-300">Download for Android</span>
      </a>
    </div>
  </div>
</section>

<!-- Decorative divider -->
<div class="relative h-px w-full" aria-hidden="true">
  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-violet/15 to-transparent"></div>
</div>

<!-- Footer -->
<footer class="relative border-t border-white/[0.03] overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-midnight to-[#080510]"></div>

  <!-- Subtle grain overlay for footer -->
  <div class="footer-grain absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="py-10 sm:py-16 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 sm:gap-10 lg:gap-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-4 lg:col-span-2">
        <a href="/unjynx-web/" class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-violet to-deep-violet flex items-center justify-center">
            <span class="font-heading font-black text-gold text-base leading-none">U</span>
          </div>
          <span class="font-heading font-bold text-xl text-purple-mist tracking-tight">UNJYNX</span>
        </a>
        <p class="font-body text-sm text-purple-mist/40 leading-relaxed mb-6 max-w-xs">
          Break the satisfactory. Unjynx your productivity. The TODO app that reaches you everywhere.
        </p>
        <div class="flex items-center gap-3">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              class="social-icon w-10 h-10 sm:w-9 sm:h-9 rounded-lg glass-light flex items-center justify-center text-purple-mist/30 transition-all duration-300"
              aria-label={social.label}
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-xs text-purple-mist/40 uppercase tracking-[0.15em] mb-5">Product</h4>
        <!-- Decorative divider line -->
        <div class="w-8 h-px bg-gradient-to-r from-violet/20 to-transparent mb-4" aria-hidden="true"></div>
        <ul class="space-y-3">
          {productLinks.map((link) => (
            <li><a href={link.href} class="font-body text-sm text-purple-mist/40 hover:text-gold transition-colors duration-300 inline-block py-1">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-xs text-purple-mist/40 uppercase tracking-[0.15em] mb-5">Company</h4>
        <div class="w-8 h-px bg-gradient-to-r from-violet/20 to-transparent mb-4" aria-hidden="true"></div>
        <ul class="space-y-3">
          {companyLinks.map((link) => (
            <li><a href={link.href} class="font-body text-sm text-purple-mist/40 hover:text-gold transition-colors duration-300 inline-block py-1">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-xs text-purple-mist/40 uppercase tracking-[0.15em] mb-5">Legal</h4>
        <div class="w-8 h-px bg-gradient-to-r from-violet/20 to-transparent mb-4" aria-hidden="true"></div>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li><a href={link.href} class="font-body text-sm text-purple-mist/40 hover:text-gold transition-colors duration-300 inline-block py-1">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Decorative horizontal divider -->
    <div class="relative h-px w-full" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/[0.05] to-transparent"></div>
    </div>

    <div class="py-4 sm:py-6 flex flex-col sm:flex-row items-center justify-between gap-2 sm:gap-3 text-center sm:text-left">
      <p class="font-body text-[11px] text-purple-mist/20">&copy; 2026 UNJYNX. All rights reserved.</p>
      <p class="font-body text-[11px] text-purple-mist/15">Made with purpose by <span class="text-violet/40 hover:text-violet/60 transition-colors duration-300">METAminds</span></p>
    </div>
  </div>
</footer>

<style>
  /* CTA gradient text (gold -> violet) */
  .cta-gradient {
    background: linear-gradient(135deg, #FFD700, #6C5CE7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Animated CTA glow orbs */
  .cta-orb-1 {
    animation: ctaOrbFloat1 6s ease-in-out infinite;
  }
  .cta-orb-2 {
    animation: ctaOrbFloat2 8s ease-in-out infinite;
  }
  .cta-orb-3 {
    animation: ctaOrbFloat3 7s ease-in-out infinite;
  }

  @keyframes ctaOrbFloat1 {
    0%, 100% { transform: translate(0, 0); opacity: 0.5; }
    33% { transform: translate(30px, -20px); opacity: 0.8; }
    66% { transform: translate(-15px, 10px); opacity: 0.4; }
  }
  @keyframes ctaOrbFloat2 {
    0%, 100% { transform: translate(0, 0); opacity: 0.4; }
    50% { transform: translate(-25px, 15px); opacity: 0.7; }
  }
  @keyframes ctaOrbFloat3 {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.3; }
    50% { transform: translate(-50%, -50%) scale(1.15); opacity: 0.6; }
  }

  /* Social icon hover with color shift */
  .social-icon:hover {
    color: #FFD700;
    border-color: rgba(255, 215, 0, 0.2);
    background: rgba(255, 215, 0, 0.08);
    box-shadow: 0 0 16px rgba(255, 215, 0, 0.1);
    transform: translateY(-2px);
  }

  /* Subtle grain overlay for footer */
  .footer-grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.015'/%3E%3C/svg%3E");
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-orb-1,
    .cta-orb-2,
    .cta-orb-3 {
      animation: none;
    }
    .social-icon:hover {
      transform: none;
    }
  }
</style>
