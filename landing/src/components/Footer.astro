---
const productLinks = [
  { label: 'Features', href: '#features' },
  { label: 'Channels', href: '#channels' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];

const companyLinks = [
  { label: 'Blog', href: '#' },
  { label: 'Support', href: '#' },
  { label: 'Careers', href: '#' },
  { label: 'Contact', href: '#' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/unjynx-web/privacy' },
  { label: 'Terms of Service', href: '/unjynx-web/terms' },
];

const socialLinks = [
  {
    label: 'Twitter / X',
    href: '#',
    icon: `<svg class="w-4 h-4" fill="currentColor" aria-hidden="true" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
