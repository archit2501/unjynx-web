---
const testimonials = [
  {
    quote: 'Finally, a TODO app that actually reminds me where I\'ll see it -- on WhatsApp. I stopped missing deadlines the day I installed UNJYNX.',
    name: 'Arjun Mehta',
    role: 'Product Manager at a Series B startup',
    initials: 'AM',
  },
  {
    quote: 'The Ghost Mode is insane. My productivity doubled in a week. No other app lets me block distractions while automatically telling my team I\'m in deep focus.',
    name: 'Priya Sharma',
    role: 'Senior Software Engineer',
    initials: 'PS',
  },
  {
    quote: 'Daily wisdom quotes are my favorite morning ritual now. The Mahabharata quotes combined with productivity insights is genuinely unique.',
    name: 'David Chen',
    role: 'Freelance Designer & Illustrator',
    initials: 'DC',
  },
  {
    quote: 'We moved our entire team to UNJYNX. The escalation chains ensure nobody misses a critical task, and the analytics are next level.',
    name: 'Sneha Reddy',
    role: 'Engineering Lead, FinTech',
    initials: 'SR',
  },
  {
    quote: 'I\'ve tried every TODO app out there. UNJYNX is the only one that stuck. Getting reminders on Telegram is a game changer for me.',
    name: 'Marco Rossi',
    role: 'Content Creator',
    initials: 'MR',
  },
  {
    quote: 'The offline-first approach is perfect for my workflow. I capture ideas on the go and everything syncs beautifully when I\'m back online.',
    name: 'Aisha Khan',
    role: 'Startup Founder',
    initials: 'AK',
  },
];

// Duplicate for seamless scroll
const row1 = testimonials.slice(0, 3);
const row2 = testimonials.slice(3, 6);
---

<section class="relative py-28 sm:py-36 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-midnight via-midnight to-midnight-light/20"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/10 to-transparent"></div>

  <div class="relative z-10">
    <!-- Section header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16 reveal">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-gold"></div>
        <span class="font-body text-xs font-semibold text-gold uppercase tracking-[0.2em]">Testimonials</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <h2 class="font-heading font-bold text-4xl sm:text-5xl md:text-[3.5rem] text-purple-mist leading-[1.1]">
          Loved by people who<br />
          <span class="text-violet/80">actually get things done</span>
        </h2>
        <p class="font-body text-purple-mist/50 text-sm max-w-xs">
          Join thousands of users who've transformed their productivity.
        </p>
      </div>
    </div>

    <!-- Scrolling testimonial rows -->
    <div class="space-y-5">
      <!-- Row 1 - scrolls left -->
      <div class="testimonial-marquee">
        <div class="flex gap-5 animate-marquee">
          {[...row1, ...row1, ...row1, ...row1].map((t) => (
            <div class="flex-shrink-0 w-[380px] sm:w-[420px] p-7 rounded-2xl border border-white/[0.04] bg-midnight-light/20 hover:border-violet/15 transition-colors duration-500 group">
              <!-- Stars -->
              <div class="flex gap-0.5 mb-5">
                {[0,1,2,3,4].map(() => (
                  <svg class="w-3.5 h-3.5 text-gold/60" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              <p class="font-body text-[15px] leading-relaxed text-purple-mist/70 group-hover:text-purple-mist/90 transition-colors duration-500 mb-7">
                "{t.quote}"
              </p>

              <div class="flex items-center gap-3.5">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-violet/60 to-deep-violet flex items-center justify-center">
                  <span class="font-heading font-bold text-[11px] text-purple-mist/90">{t.initials}</span>
                </div>
                <div>
                  <p class="font-heading font-semibold text-sm text-purple-mist">{t.name}</p>
                  <p class="font-body text-[11px] text-purple-mist/50">{t.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Row 2 - scrolls right -->
      <div class="testimonial-marquee">
        <div class="flex gap-5 animate-marquee-reverse">
          {[...row2, ...row2, ...row2, ...row2].map((t) => (
            <div class="flex-shrink-0 w-[380px] sm:w-[420px] p-7 rounded-2xl border border-white/[0.04] bg-midnight-light/20 hover:border-violet/15 transition-colors duration-500 group">
              <!-- Stars -->
              <div class="flex gap-0.5 mb-5">
                {[0,1,2,3,4].map(() => (
                  <svg class="w-3.5 h-3.5 text-gold/60" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              <p class="font-body text-[15px] leading-relaxed text-purple-mist/70 group-hover:text-purple-mist/90 transition-colors duration-500 mb-7">
                "{t.quote}"
              </p>

              <div class="flex items-center gap-3.5">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold/40 to-rich-gold flex items-center justify-center">
                  <span class="font-heading font-bold text-[11px] text-white/90">{t.initials}</span>
                </div>
                <div>
                  <p class="font-heading font-semibold text-sm text-purple-mist">{t.name}</p>
                  <p class="font-body text-[11px] text-purple-mist/50">{t.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Gradient fades on edges -->
    <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-midnight to-transparent z-20 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-midnight to-transparent z-20 pointer-events-none"></div>
  </div>
</section>

<style>
  .testimonial-marquee {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .testimonial-marquee:hover .animate-marquee,
  .testimonial-marquee:hover .animate-marquee-reverse {
    animation-play-state: paused;
  }
</style>
