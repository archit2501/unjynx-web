---
const plans = [
  {
    name: 'Free', price: { monthly: '0', annual: '0' }, description: 'Get started with the basics',
    features: [
      { text: 'Up to 25 tasks', included: true },
      { text: 'Push notifications', included: true },
      { text: '1 project', included: true },
      { text: 'Basic progress stats', included: true },
      { text: 'Daily wisdom quotes', included: true },
      { text: 'Multi-channel reminders', included: false },
      { text: 'Ghost Mode', included: false },
      { text: 'AI smart scheduling', included: false },
    ],
    cta: 'Start Free', highlighted: false,
  },
  {
    name: 'Pro', price: { monthly: '6.99', annual: '4.99' }, description: 'For individuals who mean business',
    features: [
      { text: 'Unlimited tasks', included: true },
      { text: 'All 7 channels', included: true },
      { text: 'Unlimited projects', included: true },
      { text: 'Full analytics dashboard', included: true },
      { text: 'Daily wisdom (60+ categories)', included: true },
      { text: 'Multi-channel reminders', included: true },
      { text: 'Ghost Mode', included: true },
      { text: 'AI smart scheduling', included: true },
    ],
    cta: 'Go Pro', highlighted: true,
  },
  {
    name: 'Team', price: { monthly: '8.99', annual: '6.99' }, description: 'Per user, for teams that ship',
    features: [
      { text: 'Everything in Pro', included: true },
      { text: 'Team workspaces', included: true },
      { text: 'Shared projects & tasks', included: true },
      { text: 'Team analytics', included: true },
      { text: 'SSO integration', included: true },
      { text: 'Custom escalation chains', included: true },
      { text: 'API access', included: true },
      { text: 'Dedicated support', included: true },
    ],
    cta: 'Start Trial', highlighted: false,
  },
];
---

<section id="pricing" class="relative py-16 sm:py-28 md:py-36">
  <div class="absolute inset-0 bg-gradient-to-b from-midnight via-midnight-light/20 to-midnight"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/10 to-transparent"></div>

  <!-- Decorative grid pattern background -->
  <div class="pricing-grid-bg absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-gold"></div>
        <span class="font-body text-xs font-semibold text-gold uppercase tracking-[0.2em]">Pricing</span>
        <div class="w-8 h-px bg-gold"></div>
      </div>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] text-purple-mist leading-[1.1] mb-4 sm:mb-6">
        Simple, transparent pricing
      </h2>
      <p class="font-body text-lg text-purple-mist/50 max-w-lg mx-auto mb-10">
        No hidden fees. No surprises. Cancel anytime.
      </p>

      <!-- Toggle with spring transition -->
      <div class="inline-flex items-center gap-1 p-1 rounded-xl glass-light" role="tablist" aria-label="Billing period">
        <button id="toggle-monthly" class="pricing-toggle px-5 py-3 min-h-[44px] rounded-lg font-body text-sm font-medium bg-violet/90 text-white" data-period="monthly" role="tab" aria-selected="true" aria-controls="pricing-cards">
          Monthly
        </button>
        <button id="toggle-annual" class="pricing-toggle px-5 py-3 min-h-[44px] rounded-lg font-body text-sm font-medium text-purple-mist/60 hover:text-purple-mist/80" data-period="annual" role="tab" aria-selected="false" aria-controls="pricing-cards">
          Annual <span class="ml-1.5 px-1.5 py-0.5 rounded text-[10px] font-semibold bg-gold/10 text-gold">-40%</span>
        </button>
      </div>
    </div>

    <!-- Cards -->
    <div id="pricing-cards" class="pricing-cards-container grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-5 reveal-children" role="tabpanel">
      {plans.map((plan) => (
        <div class={`tilt-card pricing-card group relative rounded-2xl transition-all duration-500 ${
          plan.highlighted
            ? 'glass-medium pro-card md:-mt-4 md:mb-0 md:pb-4'
            : 'glass-light hover:bg-white/[0.04]'
        }`}>
          {/* Animated gradient border on Pro card */}
          {plan.highlighted && (
            <div class="pro-animated-border absolute inset-0 rounded-2xl pointer-events-none"></div>
          )}

          {plan.highlighted && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 z-20">
              <span class="px-4 py-1 bg-gold text-midnight font-heading font-bold text-[10px] rounded-full uppercase tracking-wider shadow-lg shadow-gold/20">
                Most Popular
              </span>
            </div>
          )}

          <div class="relative z-10 p-6 sm:p-8">
            <div class="mb-8">
              <h3 class={`font-heading font-bold text-lg mb-1 ${plan.highlighted ? 'text-gold' : 'text-purple-mist'}`}>
                {plan.name}
              </h3>
              <p class="font-body text-xs text-purple-mist/40">{plan.description}</p>
            </div>

            <div class="mb-6 sm:mb-8 flex items-baseline gap-1">
              <span class={`font-heading font-black text-4xl sm:text-5xl text-purple-mist ${plan.highlighted ? 'price-glow' : ''}`}>
                $<span class="price-value" data-monthly={plan.price.monthly} data-annual={plan.price.annual}>{plan.price.monthly}</span>
              </span>
              {plan.price.monthly !== '0' && (
                <div class="ml-1">
                  <span class="font-body text-sm text-purple-mist/40">/mo</span>
                  <p class="font-body text-[10px] text-purple-mist/20 mt-0.5 annual-note hidden">billed annually</p>
                </div>
              )}
            </div>

            <ul class="space-y-3 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3">
                  {feature.included ? (
                    <div class="w-4 h-4 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                  ) : (
                    <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                      <div class="w-1 h-1 rounded-full bg-purple-mist/15"></div>
                    </div>
                  )}
                  <span class={`font-body text-sm ${feature.included ? 'text-purple-mist/65' : 'text-purple-mist/30'}`}>{feature.text}</span>
                </li>
              ))}
            </ul>

            <a href="#" class={`block w-full py-3.5 px-6 rounded-xl text-center font-heading font-semibold text-sm min-h-[44px] flex items-center justify-center transition-all duration-500 ${
              plan.highlighted
                ? 'bg-gold text-midnight hover:shadow-lg hover:shadow-gold/20 hover:scale-[1.02]'
                : 'glass-light text-purple-mist/70 hover:text-purple-mist hover:bg-white/[0.06]'
            }`}>
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Decorative grid pattern */
  .pricing-grid-bg {
    background-image:
      linear-gradient(rgba(108, 92, 231, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(108, 92, 231, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 20%, transparent 70%);
  }

  /* Pro card float + glow */
  .pro-card {
    border-color: rgba(255, 215, 0, 0.2);
    box-shadow: 0 20px 60px rgba(108, 92, 231, 0.1), 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transform: translateZ(20px);
    transform-style: preserve-3d;
  }

  /* Animated gradient border on Pro card */
  .pro-animated-border {
    background: conic-gradient(
      from var(--pro-border-angle, 0deg),
      transparent 0%,
      rgba(255, 215, 0, 0.35) 12%,
      rgba(108, 92, 231, 0.3) 25%,
      transparent 40%,
      rgba(255, 215, 0, 0.2) 60%,
      rgba(108, 92, 231, 0.25) 75%,
      transparent 100%
    );
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask-composite: xor;
    padding: 1.5px;
    border-radius: inherit;
    animation: proRotateBorder 5s linear infinite;
  }

  @property --pro-border-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes proRotateBorder {
    0% { --pro-border-angle: 0deg; }
    100% { --pro-border-angle: 360deg; }
  }

  /* Price text glow for Pro */
  .price-glow {
    text-shadow: 0 0 30px rgba(108, 92, 231, 0.2), 0 0 60px rgba(255, 215, 0, 0.08);
  }

  /* Spring transition on toggle */
  .pricing-toggle {
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Cards container perspective */
  .pricing-cards-container {
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  @media (prefers-reduced-motion: reduce) {
    .pro-animated-border {
      animation: none;
      background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(108, 92, 231, 0.15));
    }
    .pricing-toggle {
      transition: all 0.15s ease;
    }
  }
</style>

<script>
  const toggleMonthly = document.getElementById('toggle-monthly');
  const toggleAnnual = document.getElementById('toggle-annual');
  const priceValues = document.querySelectorAll('.price-value');
  const annualNotes = document.querySelectorAll('.annual-note');

  function setPeriod(period: string) {
    const isAnnual = period === 'annual';
    priceValues.forEach((el) => {
      const htmlEl = el as HTMLElement;
      htmlEl.textContent = isAnnual ? htmlEl.dataset.annual ?? '0' : htmlEl.dataset.monthly ?? '0';
    });
    annualNotes.forEach((el) => el.classList.toggle('hidden', !isAnnual));

    if (toggleMonthly && toggleAnnual) {
      if (isAnnual) {
        toggleAnnual.classList.add('bg-violet/90', 'text-white');
        toggleAnnual.classList.remove('text-purple-mist/60');
        toggleAnnual.setAttribute('aria-selected', 'true');
        toggleMonthly.classList.remove('bg-violet/90', 'text-white');
        toggleMonthly.classList.add('text-purple-mist/60');
        toggleMonthly.setAttribute('aria-selected', 'false');
      } else {
        toggleMonthly.classList.add('bg-violet/90', 'text-white');
        toggleMonthly.classList.remove('text-purple-mist/60');
        toggleMonthly.setAttribute('aria-selected', 'true');
        toggleAnnual.classList.remove('bg-violet/90', 'text-white');
        toggleAnnual.classList.add('text-purple-mist/60');
        toggleAnnual.setAttribute('aria-selected', 'false');
      }
    }
  }

  toggleMonthly?.addEventListener('click', () => setPeriod('monthly'));
  toggleAnnual?.addEventListener('click', () => setPeriod('annual'));
</script>
