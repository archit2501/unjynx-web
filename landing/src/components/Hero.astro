  }
  .phone-ui__notif {
    margin-top: auto;
    display: flex;
    gap: 5px;
    padding: 6px;
    border-radius: 10px;
    background: rgba(26, 16, 41, 0.95);
    border: 1px solid rgba(108, 92, 231, 0.12);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    animation: notifPulse 4s ease-in-out infinite;
  }
  @keyframes notifPulse {
    0%, 100% { transform: translateY(3px); opacity: 0.7; }
    50% { transform: translateY(0); opacity: 1; }
  }
  .phone-ui__notif-icon {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background: #25D366;
    display: grid;
    place-items: center;
    color: white;
    font-size: 8px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .phone-ui__notif-title {
    font-size: 7px;
    font-weight: 600;
    color: rgba(248, 245, 255, 0.9);
  }
  .phone-ui__notif-time {
    color: rgba(248, 245, 255, 0.3);
    font-weight: 400;
  }
  .phone-ui__notif-body {
    font-size: 6px;
    color: rgba(248, 245, 255, 0.45);
