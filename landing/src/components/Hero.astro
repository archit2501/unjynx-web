  @media (max-width: 767px) {
    .hero-phones-wrapper { max-width: 280px; margin-left: auto; margin-right: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .float-anim { animation: none; }
    .phone-ui__notif { animation: none; }
  }
