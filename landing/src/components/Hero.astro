---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Layered gradient background -->
  <div class="absolute inset-0 hero-gradient"></div>

  <!-- Animated mesh lines -->
  <div class="absolute inset-0 hero-mesh opacity-[0.015]"></div>

  <!-- Floating ambient shapes -->
  <div class="absolute top-[15%] left-[10%] w-72 h-72 bg-violet/8 rounded-full blur-[100px] animate-float" data-parallax="2"></div>
  <div class="absolute bottom-[20%] right-[8%] w-96 h-96 bg-gold/4 rounded-full blur-[120px] animate-float" style="animation-delay: -3s;" data-parallax="1.5"></div>
  <div class="absolute top-[40%] left-[60%] w-[500px] h-[500px] bg-deep-violet/5 rounded-full blur-[150px] animate-glow-pulse" data-parallax="0.5"></div>

  <!-- Decorative diagonal line -->
  <div class="absolute top-0 right-[20%] w-px h-[40vh] bg-gradient-to-b from-transparent via-violet/20 to-transparent hidden lg:block"></div>
  <div class="absolute bottom-0 left-[15%] w-px h-[30vh] bg-gradient-to-t from-transparent via-gold/10 to-transparent hidden lg:block"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <!-- Left content -->
      <div class="lg:col-span-7 text-center lg:text-left">
        <!-- Eyebrow badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-violet/20 bg-violet/5 mb-8 animate-fade-in">
          <span class="w-1.5 h-1.5 rounded-full bg-gold animate-pulse"></span>
          <span class="font-body text-xs font-medium text-purple-mist/60 tracking-wide uppercase">Now in Early Access</span>
        </div>

        <!-- Headline -->
        <h1 class="font-heading font-black tracking-tight mb-8 animate-fade-in" style="animation-delay: 0.1s;">
          <span class="block text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] leading-[0.9] text-purple-mist">
            Break the
          </span>
          <span class="block text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] leading-[0.9] mt-2 hero-text-gradient">
            satisfactory.
          </span>
        </h1>

        <!-- Sub-headline -->
        <p class="font-body text-lg sm:text-xl text-purple-mist/65 max-w-xl mx-auto lg:mx-0 mb-10 leading-relaxed animate-slide-up" style="animation-delay: 0.3s;">
          The TODO app that reaches you on <span class="text-purple-mist/90 font-medium">WhatsApp</span>, <span class="text-purple-mist/90 font-medium">Telegram</span>, <span class="text-purple-mist/90 font-medium">Instagram</span>, and 4 more channels. Because push notifications aren't enough.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center lg:items-start gap-4 animate-slide-up" style="animation-delay: 0.5s;">
          <a
            href="#"
            data-ph-capture="true"
            data-ph-capture-attribute-button="cta-app-store"
            class="group relative flex items-center gap-3 px-8 py-4 overflow-hidden rounded-2xl"
          >
            <span class="absolute inset-0 bg-gold rounded-2xl"></span>
            <span class="absolute inset-0 bg-gradient-to-r from-gold via-yellow-300 to-gold opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-2xl"></span>
            <span class="absolute inset-0 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)] rounded-2xl"></span>
            <svg class="relative w-5 h-5 text-midnight" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div class="relative text-left">
              <span class="block text-[10px] font-body text-midnight/70 leading-none">Download on the</span>
              <span class="block font-heading font-bold text-base text-midnight leading-tight">App Store</span>
            </div>
          </a>
          <a
            href="#"
            data-ph-capture="true"
            data-ph-capture-attribute-button="cta-google-play"
            class="group relative flex items-center gap-3 px-8 py-4 rounded-2xl border border-violet/20 hover:border-violet/40 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-500"
          >
            <svg class="w-5 h-5 text-purple-mist/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.834 1.64a1 1 0 0 1 0 1.74l-2.834 1.64-2.532-2.533 2.532-2.488zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/>
            </svg>
            <div class="text-left">
              <span class="block text-[10px] font-body text-purple-mist/60 leading-none">Get it on</span>
              <span class="block font-heading font-bold text-base text-purple-mist leading-tight group-hover:text-gold transition-colors duration-300">Google Play</span>
            </div>
          </a>
        </div>

        <!-- Social proof -->
        <div class="mt-12 flex items-center justify-center lg:justify-start gap-5 animate-slide-up" style="animation-delay: 0.7s;">
          <div class="flex -space-x-2.5">
            {[0,1,2,3,4].map((i) => (
              <div
                class="w-9 h-9 rounded-full border-[2px] border-midnight flex items-center justify-center text-[11px] font-bold ring-1 ring-white/5"
                style={`background: linear-gradient(135deg, hsl(${260 + i * 25}, 65%, ${45 + i * 4}%), hsl(${280 + i * 25}, 55%, ${35 + i * 4}%));`}
              >
                {String.fromCharCode(65 + i)}
              </div>
            ))}
          </div>
          <div class="text-left">
            <p class="font-heading font-bold text-sm text-gold">2,000+</p>
            <p class="font-body text-xs text-purple-mist/60">early access users</p>
          </div>
        </div>
      </div>

      <!-- Right side - App preview -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end animate-scale-in" style="animation-delay: 0.4s;">
        <div class="relative" data-parallax="0.3">
          <!-- Phone frame -->
          <div class="relative w-[260px] h-[520px] sm:w-[280px] sm:h-[560px]">
            <!-- Glow behind phone -->
            <div class="absolute -inset-8 bg-gradient-to-b from-violet/15 via-violet/5 to-gold/5 rounded-[3rem] blur-2xl"></div>

            <!-- Phone body -->
            <div class="relative w-full h-full rounded-[2.5rem] border border-violet/20 bg-midnight-light/90 backdrop-blur-xl overflow-hidden shadow-2xl shadow-violet/10">
              <!-- Dynamic Island -->
              <div class="absolute top-3 left-1/2 -translate-x-1/2 w-[90px] h-[25px] bg-black rounded-full z-20 flex items-center justify-center gap-2">
                <div class="w-2 h-2 rounded-full bg-midnight-lighter"></div>
              </div>

              <!-- Screen content -->
              <div class="absolute inset-[3px] rounded-[2.3rem] bg-gradient-to-b from-midnight-lighter via-midnight to-midnight overflow-hidden">
                <!-- Status bar -->
                <div class="flex items-center justify-between px-7 pt-4 pb-2">
                  <span class="font-body text-[10px] text-purple-mist/30 font-medium">9:41</span>
                  <div class="flex items-center gap-1">
                    <div class="flex gap-[2px]">
                      <div class="w-[3px] h-[6px] rounded-sm bg-purple-mist/25"></div>
                      <div class="w-[3px] h-[8px] rounded-sm bg-purple-mist/25"></div>
                      <div class="w-[3px] h-[10px] rounded-sm bg-purple-mist/25"></div>
                      <div class="w-[3px] h-[12px] rounded-sm bg-purple-mist/30"></div>
                    </div>
                    <div class="w-6 h-3 rounded-sm border border-purple-mist/20 ml-1 flex items-center justify-end pr-[2px]">
                      <div class="w-3.5 h-[6px] rounded-[1px] bg-gold/60"></div>
                    </div>
                  </div>
                </div>

                <!-- App header -->
                <div class="px-5 pt-1 pb-3 flex items-center justify-between">
                  <div>
                    <span class="font-heading font-bold text-base text-gold">UNJYNX</span>
                    <p class="font-body text-[9px] text-purple-mist/30 mt-0.5">Good morning, Arjun</p>
                  </div>
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet to-deep-violet flex items-center justify-center">
                    <span class="text-[10px] font-bold text-gold">A</span>
                  </div>
                </div>

                <!-- Daily wisdom card -->
                <div class="mx-4 p-3 rounded-xl bg-gradient-to-r from-violet/10 to-gold/5 border border-violet/10 mb-3">
                  <p class="font-body text-[8px] text-gold/70 uppercase tracking-wider mb-1">Daily Wisdom</p>
                  <p class="font-body text-[10px] text-purple-mist/70 italic leading-relaxed">"The impediment to action advances action."</p>
                  <p class="font-body text-[8px] text-purple-mist/30 mt-1">— Marcus Aurelius</p>
                </div>

                <!-- Tasks -->
                <div class="px-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-heading font-semibold text-[11px] text-purple-mist/80">Today's Tasks</span>
                    <span class="font-body text-[9px] text-violet">3 remaining</span>
                  </div>

                  <div class="space-y-2">
                    <!-- Completed task -->
                    <div class="flex items-center gap-2.5 p-2.5 rounded-xl bg-white/[0.02]">
                      <div class="w-5 h-5 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0">
                        <svg class="w-3 h-3 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                        </svg>
                      </div>
                      <span class="font-body text-[10px] text-purple-mist/30 line-through">Review Q4 metrics</span>
                    </div>
                    <!-- Active task -->
                    <div class="flex items-center gap-2.5 p-2.5 rounded-xl bg-violet/[0.06] border border-violet/10">
                      <div class="w-5 h-5 rounded-full border-[1.5px] border-violet/40 flex-shrink-0"></div>
                      <div class="flex-1 min-w-0">
                        <span class="font-body text-[10px] text-purple-mist/80 block">Ship landing page v2</span>
                        <div class="flex items-center gap-1.5 mt-1">
                          <span class="text-[7px] px-1.5 py-0.5 rounded-full bg-violet/15 text-violet font-medium">High</span>
                          <span class="text-[7px] text-purple-mist/25">via WhatsApp</span>
                        </div>
                      </div>
                    </div>
                    <!-- Task -->
                    <div class="flex items-center gap-2.5 p-2.5 rounded-xl bg-white/[0.02]">
                      <div class="w-5 h-5 rounded-full border-[1.5px] border-purple-mist/15 flex-shrink-0"></div>
                      <span class="font-body text-[10px] text-purple-mist/50">Prepare investor deck</span>
                    </div>
                    <!-- Task -->
                    <div class="flex items-center gap-2.5 p-2.5 rounded-xl bg-white/[0.02]">
                      <div class="w-5 h-5 rounded-full border-[1.5px] border-purple-mist/15 flex-shrink-0"></div>
                      <span class="font-body text-[10px] text-purple-mist/50">Call with design team</span>
                    </div>
                  </div>
                </div>

                <!-- WhatsApp notification overlay -->
                <div class="absolute bottom-12 left-3 right-3 phone-notification">
                  <div class="p-3 rounded-2xl bg-midnight-lighter/95 backdrop-blur-lg border border-violet/15 shadow-xl shadow-black/30">
                    <div class="flex items-start gap-2.5">
                      <div class="w-7 h-7 rounded-lg bg-[#25D366] flex items-center justify-center flex-shrink-0 mt-0.5">
                        <span class="text-white font-bold text-[9px]">W</span>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                          <span class="font-heading font-semibold text-[10px] text-purple-mist">UNJYNX Reminder</span>
                          <span class="font-body text-[8px] text-purple-mist/30">now</span>
                        </div>
                        <p class="font-body text-[9px] text-purple-mist/50 mt-0.5 leading-relaxed">Ship landing page v2 is due in 15 min. Time to lock in.</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Home indicator -->
              <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-28 h-1 rounded-full bg-purple-mist/15"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-fade-in" style="animation-delay: 1.2s;">
    <span class="font-body text-[10px] text-purple-mist/20 uppercase tracking-[0.2em]">Scroll</span>
    <div class="w-5 h-8 rounded-full border border-purple-mist/10 flex items-start justify-center p-1.5">
      <div class="w-1 h-1.5 rounded-full bg-gold/60 animate-bounce"></div>
    </div>
  </div>
</section>

<style>
  .hero-gradient {
    background:
      radial-gradient(ellipse 70% 50% at 30% 20%, rgba(108, 92, 231, 0.1) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 80%, rgba(255, 215, 0, 0.04) 0%, transparent 50%),
      radial-gradient(ellipse 60% 60% at 50% 50%, rgba(107, 33, 168, 0.06) 0%, transparent 50%);
  }

  .hero-mesh {
    background-image:
      linear-gradient(rgba(248, 245, 255, 1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(248, 245, 255, 1) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  .hero-text-gradient {
    background: linear-gradient(135deg, #FFD700 0%, #B8860B 40%, #FFD700 60%, #6C5CE7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .phone-notification {
    animation: slideNotification 4s ease-in-out infinite;
  }

  @keyframes slideNotification {
    0%, 100% { transform: translateY(10px); opacity: 0; }
    15%, 85% { transform: translateY(0); opacity: 1; }
    90% { transform: translateY(-5px); opacity: 0; }
  }
</style>
