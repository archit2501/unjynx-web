  }
  .phone-ui__ch-banner {
    border-radius: 8px;
    padding: 8px;
    background: linear-gradient(135deg, rgba(108, 92, 231, 0.25), rgba(255, 215, 0, 0.1));
    border: 1px solid rgba(108, 92, 231, 0.15);
  }
  .phone-ui__ch-banner-eyebrow {
    font-size: 5px;
    letter-spacing: 0.15em;
