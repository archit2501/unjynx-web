---
const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
    </svg>`,
    title: 'Multi-Channel Reminders',
    description: 'WhatsApp, Telegram, Instagram, SMS, Discord, Slack, and Email. Your tasks follow you where you already are.',
    span: 'col-span-1 sm:col-span-2 lg:col-span-1',
    accent: '#25D366',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09zM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456zM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423z" />
    </svg>`,
    title: 'Smart Scheduling',
    description: 'AI learns your energy patterns, peak hours, and habits to optimize your day automatically.',
    span: 'col-span-1 lg:col-span-2',
    accent: '#6C5CE7',
    featured: true,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
    </svg>`,
    title: 'Ghost Mode',
    description: 'Enter deep focus. Block apps, silence noise, and let your team know you\'re in the zone.',
    span: 'col-span-1',
    accent: '#8B8B8B',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
    </svg>`,
    title: 'Daily Wisdom',
    description: 'Curated quotes from Mahabharata, Stoics, and history\'s greatest minds. 60+ categories.',
    span: 'col-span-1',
    accent: '#FFD700',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125z" />
    </svg>`,
    title: 'Progress Dashboard',
    description: 'Strava-like analytics. Streak rings, heatmaps, personal bests, and weekly insights.',
    span: 'col-span-1 lg:col-span-2',
    accent: '#00B4D8',
    featured: true,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
    </svg>`,
    title: 'Cross-Platform',
    description: 'Android, iOS, Apple Watch, Wear OS. Offline-first with conflict-free sync everywhere.',
    span: 'col-span-1',
    accent: '#A855F7',
  },
];
---

<section id="features" class="relative py-28 sm:py-36">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-midnight via-midnight-light/40 to-midnight"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/15 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-3xl mb-20 reveal">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-gold"></div>
        <span class="font-body text-xs font-semibold text-gold uppercase tracking-[0.2em]">Why UNJYNX</span>
      </div>
      <h2 class="font-heading font-bold text-4xl sm:text-5xl md:text-[3.5rem] text-purple-mist leading-[1.1] mb-6">
        Everything you need.<br />
        <span class="text-violet/80">Nothing you don't.</span>
      </h2>
      <p class="font-body text-lg text-purple-mist/60 max-w-xl leading-relaxed">
        Six powerful features that transform how you manage tasks, stay focused, and actually get things done.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5 reveal-children">
      {features.map((feature) => (
        <div class={`group relative overflow-hidden rounded-2xl ${feature.span} ${feature.featured ? 'p-8 sm:p-10' : 'p-7 sm:p-8'}`}>
          <!-- Background layers -->
          <div class="absolute inset-0 bg-midnight-light/40 border border-white/[0.04] rounded-2xl transition-all duration-700 group-hover:border-white/[0.08]"></div>
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700" style={`background: radial-gradient(ellipse at 50% 0%, ${feature.accent}08 0%, transparent 70%);`}></div>

          <!-- Corner accent -->
          <div class="absolute top-0 right-0 w-24 h-24 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
            <div class="absolute top-4 right-4 w-8 h-px transition-all duration-500" style={`background: ${feature.accent}40;`}></div>
            <div class="absolute top-4 right-4 w-px h-8 transition-all duration-500" style={`background: ${feature.accent}40;`}></div>
          </div>

          <div class="relative z-10">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-500 group-hover:scale-110"
              style={`background: ${feature.accent}10; color: ${feature.accent};`}>
              <Fragment set:html={feature.icon} />
            </div>

            <!-- Title -->
            <h3 class="font-heading font-semibold text-lg text-purple-mist mb-3 group-hover:text-white transition-colors duration-300">
              {feature.title}
            </h3>

            <!-- Description -->
            <p class="font-body text-sm leading-relaxed text-purple-mist/60 group-hover:text-purple-mist/80 transition-colors duration-500">
              {feature.description}
            </p>

            {feature.featured && (
              <div class="mt-6 flex items-center gap-2 text-purple-mist/30 group-hover:text-violet transition-colors duration-300">
                <span class="font-body text-xs font-medium">Learn more</span>
                <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
