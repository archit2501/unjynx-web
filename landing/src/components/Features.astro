---

<section id="features" class="relative py-16 sm:py-28 md:py-36">
  <div class="absolute inset-0 bg-gradient-to-b from-midnight via-midnight-light/60 to-midnight"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet/15 to-transparent"></div>
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-violet/[0.04] rounded-full blur-[150px]"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-gold/[0.03] rounded-full blur-[120px]"></div>

  <!-- Decorative parallax floating elements -->
  <div
    class="absolute top-[12%] right-[8%] w-2 h-2 rounded-full bg-gold/20"
    data-parallax
    data-parallax-speed="0.05"
    aria-hidden="true"
  ></div>
  <div
    class="absolute top-[30%] left-[5%] w-1.5 h-1.5 rounded-full bg-violet/25"
    data-parallax
    data-parallax-speed="0.03"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-[25%] right-[15%] w-20 h-px bg-gradient-to-r from-transparent via-violet/10 to-transparent"
    data-parallax
    data-parallax-speed="0.04"
    aria-hidden="true"
  ></div>
  <div
    class="absolute top-[55%] left-[12%] w-16 h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"
    data-parallax
    data-parallax-speed="0.06"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-[15%] left-[25%] w-1 h-1 rounded-full bg-gold/15"
    data-parallax
    data-parallax-speed="0.07"
    aria-hidden="true"
  ></div>
  <div
    class="absolute top-[70%] right-[30%] w-2.5 h-2.5 rounded-full bg-violet/10 blur-[1px]"
    data-parallax
    data-parallax-speed="0.035"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <!-- Header -->
    <div class="max-w-3xl mb-12 sm:mb-16 md:mb-20 reveal">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-gold"></div>
        <span class="font-body text-xs font-semibold text-gold uppercase tracking-[0.2em]">Why UNJYNX</span>
      </div>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] text-purple-mist leading-[1.1] mb-4 sm:mb-6">
        Everything you need.<br />
        <span class="text-violet/80">Nothing you don't.</span>
      </h2>
      <p class="font-body text-lg text-purple-mist/55 max-w-xl leading-relaxed">
        Six powerful features that transform how you manage tasks, stay focused, and actually get things done.
      </p>
    </div>

    <!-- Bento grid with CSS perspective -->
    <div class="bento-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 lg:gap-5 reveal-children">
      {features.map((feature) => (
        <div class={`tilt-card group relative overflow-hidden rounded-2xl ${feature.span} ${feature.featured ? 'p-6 sm:p-8 md:p-10' : 'p-5 sm:p-7 md:p-8'} glass-medium ${feature.title === 'Smart Scheduling' ? 'card-highlight' : ''} hover:bg-white/[0.06] transition-all duration-700 ${feature.featured ? 'featured-card' : ''}`}>

          <!-- Animated gradient border for featured cards -->
          {feature.featured && (
            <div class="animated-border-glow absolute inset-0 rounded-2xl pointer-events-none"></div>
          )}

          <!-- Top accent on hover -->
          <div class="absolute top-0 left-0 right-0 h-px transition-opacity duration-700 opacity-0 group-hover:opacity-100" style={`background: linear-gradient(90deg, transparent, ${feature.accent}60, transparent);`}></div>

          <!-- Corner accent -->
          <div class="absolute top-0 right-0 w-24 h-24 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
            <div class="absolute top-4 right-4 w-8 h-px transition-all duration-500" style={`background: ${feature.accent}40;`}></div>
            <div class="absolute top-4 right-4 w-px h-8 transition-all duration-500" style={`background: ${feature.accent}40;`}></div>
          </div>

          <div class="relative z-10">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-all duration-500 group-hover:scale-110"
              style={`background: ${feature.accent}10; color: ${feature.accent};`}>
              <Fragment set:html={feature.icon} />
            </div>

            <h3 class="font-heading font-semibold text-lg text-purple-mist mb-3 group-hover:text-white transition-colors duration-300">
              {feature.title}
            </h3>

            <p class="font-body text-sm leading-relaxed text-purple-mist/55 group-hover:text-purple-mist/75 transition-colors duration-500">
              {feature.description}
            </p>

            <span class="feature-tag">{feature.tag}</span>

            {feature.featured && (
              <div class="mt-6 flex items-center gap-2 text-purple-mist/25 group-hover:text-violet transition-colors duration-300">
                <span class="font-body text-xs font-medium">Learn more</span>
                <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* CSS perspective on grid container for scroll depth */
  .bento-grid {
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  /* Animated gradient border for featured cards */
  .animated-border-glow {
    background: conic-gradient(
      from var(--border-angle, 0deg),
      transparent 0%,
      rgba(108, 92, 231, 0.4) 15%,
      rgba(255, 215, 0, 0.3) 30%,
      transparent 50%,
      rgba(108, 92, 231, 0.3) 65%,
      rgba(255, 215, 0, 0.2) 80%,
      transparent 100%
    );
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask-composite: xor;
    padding: 1px;
    border-radius: inherit;
    animation: rotateBorder 4s linear infinite;
  }

  @keyframes rotateBorder {
    0% { --border-angle: 0deg; }
    100% { --border-angle: 360deg; }
  }

  /* Register the custom property for animation */
  @property --border-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  /* Featured card subtle inner glow */
  .featured-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at 50% 0%, rgba(108, 92, 231, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .animated-border-glow {
      animation: none;
      background: linear-gradient(135deg, rgba(108, 92, 231, 0.2), rgba(255, 215, 0, 0.15));
    }
  }
</style>
