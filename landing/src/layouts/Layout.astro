    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }

      html {
        font-family: 'DM Sans', sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background-color: #0F0A1A;
        color: #F8F5FF;
        overflow-x: hidden;
      }

      ::selection {
        background-color: rgba(108, 92, 231, 0.4);
        color: #FFD700;
      }

      /* Film grain */
      .grain-overlay::before {
        content: '';
        position: fixed;
        inset: -200%;
        width: 400%;
        height: 400%;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
        animation: grain 8s steps(10) infinite;
      }

      /* Glassmorphism tiers */
      .glass-heavy {
        backdrop-filter: blur(20px) saturate(1.3);
        -webkit-backdrop-filter: blur(20px) saturate(1.3);
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.15);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }

      .glass-medium {
        backdrop-filter: blur(12px) saturate(1.2);
        -webkit-backdrop-filter: blur(12px) saturate(1.2);
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.04);
      }

      .glass-light {
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.07);
        box-shadow: 0 2px 16px rgba(0, 0, 0, 0.15);
      }

      /* Scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }

      .reveal-left {
        opacity: 0;
        transform: translateX(-60px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-left.visible { opacity: 1; transform: translateX(0); }

      .reveal-right {
        opacity: 0;
        transform: translateX(60px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-right.visible { opacity: 1; transform: translateX(0); }

      .reveal-children > * {
        opacity: 0;
        transform: translateY(25px);
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-children.visible > *:nth-child(1) { transition-delay: 0.05s; }
      .reveal-children.visible > *:nth-child(2) { transition-delay: 0.1s; }
      .reveal-children.visible > *:nth-child(3) { transition-delay: 0.15s; }
      .reveal-children.visible > *:nth-child(4) { transition-delay: 0.2s; }
      .reveal-children.visible > *:nth-child(5) { transition-delay: 0.25s; }
      .reveal-children.visible > *:nth-child(6) { transition-delay: 0.3s; }
      .reveal-children.visible > *:nth-child(7) { transition-delay: 0.35s; }
      .reveal-children.visible > *:nth-child(8) { transition-delay: 0.4s; }
      .reveal-children.visible > *:nth-child(9) { transition-delay: 0.45s; }
      .reveal-children.visible > *:nth-child(10) { transition-delay: 0.5s; }
      .reveal-children.visible > * { opacity: 1; transform: translateY(0); }

      /* 3D card tilt */
      .tilt-card {
        transform-style: preserve-3d;
        transition: transform 0.3s ease;
      }
      .tilt-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: radial-gradient(
          circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
          rgba(255, 255, 255, 0.08),
          transparent 60%
        );
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s;
        z-index: 1;
      }
      .tilt-card:hover::before { opacity: 1; }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #0F0A1A; }
      ::-webkit-scrollbar-thumb { background: rgba(108, 92, 231, 0.3); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: rgba(108, 92, 231, 0.5); }

      /* Skip-to-content */
      .skip-to-content {
        position: absolute;
        top: -100%;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        padding: 0.75rem 1.5rem;
        background: #FFD700;
        color: #0F0A1A;
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 0.875rem;
        border-radius: 0 0 0.75rem 0.75rem;
        transition: top 0.2s ease;
      }
      .skip-to-content:focus { top: 0; outline: 2px solid #6C5CE7; outline-offset: 2px; }

      /* Snap sections */
      .snap-section {
        scroll-snap-align: start;
        min-height: 100vh;
      }

      /* Hero grid lines (subtle dot grid background) */
      .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(circle, rgba(108, 92, 231, 0.15) 1px, transparent 1px);
        background-size: 40px 40px;
        opacity: 0.4;
        pointer-events: none;
        mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black, transparent);
        -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black, transparent);
      }

      /* Feature card highlight gradient */
      .card-highlight {
        background: linear-gradient(135deg, rgba(108, 92, 231, 0.12) 0%, rgba(255, 215, 0, 0.05) 100%) !important;
        border-color: rgba(108, 92, 231, 0.25) !important;
      }

      /* Feature tags */
      .feature-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        margin-top: 1rem;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        background: rgba(255, 215, 0, 0.08);
        color: #FFD700;
        border: 1px solid rgba(255, 215, 0, 0.15);
      }

      /* Scroll-to-top button */
      .scroll-top-btn {
        position: fixed;
        bottom: 1rem;
        right: 1rem;
        z-index: 100;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(108, 92, 231, 0.9);
        color: white;
        display: grid;
        place-items: center;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.15s ease;
        pointer-events: none;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .scroll-top-btn.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .scroll-top-btn:hover {
        box-shadow: 0 0 40px rgba(108, 92, 231, 0.4);
        transform: translateY(-3px);
        background: rgba(108, 92, 231, 1);
      }

      @media (min-width: 640px) {
        .scroll-top-btn {
          bottom: 2rem;
          right: 2rem;
          width: 48px;
          height: 48px;
        }
      }

      /* Reduced motion */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        .reveal, .reveal-left, .reveal-right, .reveal-children > * {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
        .grain-overlay::before { animation: none !important; }
      }
    </style>
  </head>
  <body class="grain-overlay">
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <slot />

    <button class="scroll-top-btn" id="scroll-top-btn" aria-label="Scroll back to top">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M9 14V4M4 9L9 4L14 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <script>
      // Intersection Observer for scroll reveals
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
      );
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-children').forEach((el) => observer.observe(el));

      // 3D tilt on glass cards — disabled on touch devices
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      if (!prefersReducedMotion && !isTouchDevice) {
        document.querySelectorAll('.tilt-card').forEach((card) => {
          const el = card as HTMLElement;
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width;
            const y = (e.clientY - rect.top) / rect.height;
            const rotateX = (y - 0.5) * -8;
            const rotateY = (x - 0.5) * 8;
            el.style.transform = `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
            el.style.setProperty('--mouse-x', `${x * 100}%`);
            el.style.setProperty('--mouse-y', `${y * 100}%`);
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = 'perspective(800px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
          });
        });
      }

      // Scroll-to-top button
      const scrollTopBtn = document.getElementById('scroll-top-btn');
      window.addEventListener('scroll', () => {
        scrollTopBtn?.classList.toggle('visible', window.scrollY > 400);
      }, { passive: true });
      scrollTopBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
